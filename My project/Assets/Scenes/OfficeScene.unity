  m_Script: {fileID: 11500000, guid: 46b73d023e84943eaa8abdb843f3c1ba, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EmailUIManager
  emails:
  - sender: james.park@parkventures.com
    subject: 'Re: Thursday''s Meeting'
    date: 2011/09/06
    body: "Rich, confirmed for Thursday at 2pm. Bringing the new analyst along, hope
      that's fine. Also \u2014 are we still on for the game this weekend? My son
      keeps asking."
  - sender: no-reply@premiumgolf.com
    subject: Your Tee Time Confirmation
    date: 2012/04/21
    body: Dear Mr. Rich, your tee time for Saturday 8:00am has been confirmed. Please
      arrive 15 minutes early. Weather forecast looks clear. See you on the course.
  - sender: james.park@parkventures.com
    subject: 'Re: Thursday''s Meeting'
    date: 2011/09/06
    body: "Rich, confirmed for Thursday at 2pm. Bringing the new analyst along, hope
      that's fine. Also \u2014 are we still on for the game this weekend? My son
      keeps asking."
  - sender: linda.chao@richcorp-internal.com
    subject: "Board Meeting Minutes \u2014 October"
    date: 2013/10/15
    body: Mr. Rich, attached are the minutes from yesterday's board meeting. Three
      members raised concerns about the eastern expansion again. I've flagged the
      key points. Let me know if you'd like me to schedule a follow-up before the
      end of the month.
  - sender: james.park@parkventures.com
    subject: The Henderson Deal
    date: 2015/07/30
    body: "Rich, Henderson finally signed. Took long enough. Dinner is on me this
      Friday \u2014 no excuses. Bring Angel if you want, the restaurant has outdoor
      seating now."
  - sender: linda.chao@richcorp-internal.com
    subject: Your 3pm Has Been Moved
    date: 2016/02/11
    body: Mr. Rich, your 3pm call with the Singapore office has been moved to 4:30pm.
      Also, the dry cleaning you left last Tuesday is still at the front desk. I'll
      leave it outside your office.
  - sender: dr.morris@heartcareclinic.com
    subject: 'Follow-up: Last Week''s Results'
    date: 2017/09/19
    body: Mr. Rich, your recent test results show your blood pressure remains elevated.
      I'd like to see you again before the end of the month. Please try to cut back
      on the late nights. I mean it this time.
  - sender: dr.morris@heartcareclinic.com
    subject: 'Follow-up: Last Week''s Results'
    date: 2017/09/19
    body: Mr. Rich, your recent test results show your blood pressure remains elevated.
      I'd like to see you again before the end of the month. Please try to cut back
      on the late nights. I mean it this time.
  - sender: no-reply@arkenzoo.com
    subject: Your Order Has Shipped
    date: 2018/05/03
    body: Hi Rich, your monthly order of Angel's food has shipped and will arrive
      Thursday. You've also earned enough points for a free bag of treats. We've
      added them to your order automatically.
  - sender: james.park@parkventures.com
    subject: Retired???
    date: 2019/11/22
    body: Rich, heard a rumor you're thinking about stepping back from the board.
      Can't tell if that's true or if someone's messing with me. Either way, call
      me. We need to talk before you make any decisions.
  - sender: linda.chao@richcorp-internal.com
    subject: Checking In
    date: 2020/08/14
    body: Mr. Rich, you missed the Monday briefing and didn't respond to my calls.
      I rescheduled everything to next week. I hope you're alright. Looking forward
      to hear from you!
  emailListContainer: {fileID: 1397099806}
  emailItemPrefab: {fileID: 6309114345478861894, guid: b1e177197d7a8451788b33d1c1ebafc7, type: 3}
  detailPanel: {fileID: 650424054}
